# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Obsidian
.obsidian/
!vault-template/.obsidian/

# OpenCode local config
.opencode/config.json

# Node
node_modules/

# Python
__pycache__/
*.py[cod]

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# User data (these are generated at deploy time)
