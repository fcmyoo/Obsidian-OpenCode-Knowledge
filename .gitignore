raw/*
!vault-template/raw/.gitkeep

# Logs
*.log

# Runtime artifacts
tmp-live-vault/
.codebase-memory/
.opencode/node_modules/
reasonix.toml

# Spec workflow generated files
.spec-workflow/approvals/
.spec-workflow/archive/

# Generated helper scripts
scripts/check-env.sh
scripts/CLAUDE.md
